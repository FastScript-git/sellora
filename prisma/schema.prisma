generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum AIEmployeeStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum KnowledgeSourceType {
  WEBSITE
  PDF
  FAQ
  NOTE
}

enum AIEmployeeLanguage {
  EN
  UK
}

model User {
  id             String            @id @default(cuid())
  externalAuthId String            @unique
  email          String            @unique
  firstName      String?
  lastName       String?
  imageUrl       String?
  memberships    WorkspaceMember[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([email])
}

model Workspace {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  memberships WorkspaceMember[]
  aiEmployees AIEmployee[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  role        WorkspaceRole @default(MEMBER)
  userId      String
  workspaceId String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

model AIEmployee {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  name        String
  role        String
  description String?

  status   AIEmployeeStatus   @default(DRAFT)
  language AIEmployeeLanguage @default(EN)
  tone     String?

  instructions String?

  identity      String?
  goals         String?
  rules         String?
  responseStyle String?
  restrictions  String?

  knowledgeSources KnowledgeSource[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, status])
}

model KnowledgeSource {
  id String @id @default(cuid())

  employeeId String
  employee   AIEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  type KnowledgeSourceType

  title String

  sourceUrl String?

  content String?

  status String @default("PENDING")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([employeeId, type])
}
